PORT=5000
MONGO_URI=mongodb://localhost:27017/tradex
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
NODE_ENV=development

# ─── Alpha Vantage — Real-Time Market Prices ──────────────────────
# Sign up free at https://www.alphavantage.co/support/#api-key
# Free tier: 25 requests/day, 500/month.
# The app tracks usage in .av_budget.json and stops all AV calls once the
# daily cap is hit, falling back to the last cached price automatically.
ALPHAVANTAGE_API_KEY=

# How long (ms) before a cached price is considered stale and re-fetched.
# At 3 DEFAULT_TRACKED_SYMBOLS and 25 calls/day, keep this >= 3 hours
# so the scheduler doesn't exhaust the budget. Default: 3h (10800000 ms).
PRICE_STALE_MS=10800000

# How often (ms) the background scheduler refreshes the default symbols.
# Default: 3 hours. Matches PRICE_STALE_MS so each cycle uses exactly 1
# call per symbol. Reduce only if you have a paid AV plan.
PRICE_POLL_INTERVAL_MS=10800000

# Hard daily call cap for Alpha Vantage (default 23, leaving 2 for testing).
# AV free tier is 25/day. Raise if you upgrade to a paid plan.
AV_DAILY_LIMIT=23

# ─── Newsdata.io — Financial News Feed ────────────────────────────
# Sign up free at https://newsdata.io — click "Get API Key".
# Free tier: 200 requests/day, 10 articles per response.
# The app caches news per symbol for NEWS_CACHE_HOURS hours (default 6h)
# so a typical install with <10 watched symbols uses well under 50 calls/day.
NEWSDATA_API_KEY=

# Hours to cache news articles before refreshing from Newsdata.io.
# Default: 6h. Lower only if you have headroom in your daily quota.
NEWS_CACHE_HOURS=6

# Hard daily call cap for Newsdata.io (default 180, out of 200 free).
ND_DAILY_LIMIT=180

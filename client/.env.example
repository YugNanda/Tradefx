# ── Local Development ──────────────────────────────────────────────
# Leave VITE_API_URL empty in dev. Vite proxy handles /api → localhost:5000.
VITE_API_URL=

# ── Vercel Production ──────────────────────────────────────────────
# Set this in the Vercel dashboard → Project → Settings → Environment Variables
# to your Render backend URL (no trailing slash).
# VITE_API_URL=https://tradex-server.onrender.com
